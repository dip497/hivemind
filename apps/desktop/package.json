{
  "name": "@hivemind/desktop",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:bridge": "tsx src/dev-bridge/server.ts",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --linux AppImage",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:nb": "playwright test",
    "test:e2e:diff": "playwright test shipped-features.spec.ts",
    "test:e2e:issues": "playwright test issues-tile.spec.ts issue-create.spec.ts init-workspace.spec.ts",
    "test:e2e:canvas": "playwright test resize.spec.ts tile-move.spec.ts frame.spec.ts frame-contains-tile.spec.ts",
    "test:e2e:persist": "playwright test shipped-persistence.spec.ts",
    "postinstall": "echo 'skip electron-builder install-app-deps in dev (use @electron/rebuild manually)'"
  },
  "build": {
    "appId": "com.hivemind.desktop",
    "productName": "hivemind",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/@lydell/node-pty/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "synopsis": "Kanban PM + infinite canvas + AI coding agents",
      "description": "Local-first issue tracker, infinite canvas, and Claude Code integration in a single Electron desktop app.",
      "executableName": "hivemind",
      "icon": "icons/icon.png",
      "artifactName": "hivemind-${version}-${arch}.AppImage"
    },
    "directories": {
      "output": "dist-electron"
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hivemind/core": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@lydell/node-pty": "catalog:",
    "@pierre/diffs": "catalog:",
    "@pierre/trees": "1.0.0-beta.3",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "catalog:",
    "@shikijs/core": "^3.23.0",
    "@shikijs/engine-javascript": "^3.23.0",
    "@shikijs/engine-oniguruma": "^3.23.0",
    "@shikijs/langs": "^3.23.0",
    "@shikijs/types": "^3.23.0",
    "@tanstack/react-query": "catalog:",
    "@xterm/addon-fit": "catalog:",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "catalog:",
    "@xterm/headless": "catalog:",
    "@xterm/xterm": "catalog:",
    "@xyflow/react": "catalog:",
    "chokidar": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.9",
    "lucide-react": "catalog:",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "path-browserify": "^1.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shiki": "^3.23.0",
    "simple-git": "catalog:",
    "sonner": "catalog:",
    "ssh2": "^1.17.0",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "^1.4.0",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@electron/rebuild": "catalog:",
    "@hivemind/tsconfig": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "electron-vite": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.22.1",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
